# VK community notifications for website VK users
# Add these variables only to Render backend, not to Vercel.

# Numeric community/group ID without minus, for example: 123456789
VK_COMMUNITY_ID=

# Community access token with Messages permission, for example: vk1.a.xxxxx
VK_COMMUNITY_TOKEN=

# VK API version. Leave this value unless VK changes API requirements.
VK_API_VERSION=5.199
