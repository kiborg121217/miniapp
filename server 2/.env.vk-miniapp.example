# VK Mini App stage 1
# Без этого ключа приложение внутри ВК откроется, но авто-вход по launch-параметрам будет пропущен.
# Если VK даст "Защищённый ключ" приложения, добавь его сюда в Render.
VK_MINI_APP_SECRET=

# Уже существующие переменные VK ID входа
VK_ID_CLIENT_ID=
VK_ID_REDIRECT_URI=https://miniapp-9vf5.vercel.app/auth/vk/callback

# Уже существующие переменные VK-сообщества для уведомлений
VK_COMMUNITY_ID=
VK_COMMUNITY_TOKEN=
VK_API_VERSION=5.199
