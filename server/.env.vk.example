# VK ID auth for website login
# Create VK ID app at https://id.vk.com/about/business/go
VK_ID_CLIENT_ID=12345678
# Leave empty if VK ID token endpoint does not require it in your app settings.
# Keep it server-side only. Do not add it to Vercel client env.
VK_ID_CLIENT_SECRET=
VK_ID_REDIRECT_URI=https://miniapp-9vf5.vercel.app/auth/vk/callback
# Optional, default: 10 minutes
VK_ID_STATE_TTL_MS=600000
